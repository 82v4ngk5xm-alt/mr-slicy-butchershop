+ import Phaser from "phaser";
+ import { DELIVERIES, GAME } from "../game/constants.js";
+ import { runState } from "../game/state.js";
+ import { addLabel } from "../game/ui.js";
+ 
+ const WALL_THICKNESS = 30;
+ const INTERACT_DISTANCE = 44;
+ 
+ export class DeliveryScene extends Phaser.Scene {
+   constructor() {
+     super("delivery");
+   }
+ 
+   create(data) {
+     this.deliveryIndex = data?.deliveryIndex ?? 0;
+     this.delivery = DELIVERIES[this.deliveryIndex];
+ 
+     this.hasDelivered = false;
+     this.hasKey = false;
+     this.switchesActive = 0;
+     this.isExitUnlocked = false;
+ 
+     this.interactKey = this.input.keyboard.addKey("E");
+     this.keys = this.input.keyboard.addKeys({
+       up: "W",
+       down: "S",
+       left: "A",
+       right: "D",
+       sprint: Phaser.Input.Keyboard.KeyCodes.SHIFT,
+       upAlt: Phaser.Input.Keyboard.KeyCodes.UP,
+       downAlt: Phaser.Input.Keyboard.KeyCodes.DOWN,
+       leftAlt: Phaser.Input.Keyboard.KeyCodes.LEFT,
+       rightAlt: Phaser.Input.Keyboard.KeyCodes.RIGHT,
+     });
+ 
+     this.createRoom();
+     this.createActors();
+     this.createObjectives();
+     this.createUi();
+     this.configureCollisions();
+     this.startAmbientEvents();
+   }
+ 
+   createRoom() {
+     const { width, height } = this.scale;
+     this.walls = this.physics.add.staticGroup();
+ 
+     const makeWall = (x, y, w, h) => {
+       const wall = this.add.rectangle(x, y, w, h, GAME.colors.wall);
+       this.physics.add.existing(wall, true);
+       this.walls.add(wall);
+     };
+ 
+     makeWall(width / 2, WALL_THICKNESS / 2, width, WALL_THICKNESS);
+     makeWall(width / 2, height - WALL_THICKNESS / 2, width, WALL_THICKNESS);
+     makeWall(WALL_THICKNESS / 2, height / 2, WALL_THICKNESS, height);
+     makeWall(width - WALL_THICKNESS / 2, height / 2, WALL_THICKNESS, height);
+ 
+     const floor = this.add.rectangle(width / 2, height / 2, width - 60, height - 60, GAME.colors.floor);
+     floor.setDepth(-2);
+ 
+     this.crates = this.physics.add.staticGroup();
+     this.addCrate(250, 215, 80, 40);
+     this.addCrate(390, 355, 110, 40);
+     this.addCrate(620, 240, 70, 80);
+     this.addCrate(760, 385, 120, 40);
+ 
+     this.exitDoor = this.add.rectangle(width - 72, height / 2, 18, 120, GAME.colors.exitClosed);
+     this.physics.add.existing(this.exitDoor, true);
+   }
+ 
+   addCrate(x, y, width, height) {
+     const crate = this.add.rectangle(x, y, width, height, GAME.colors.crate);
+     this.physics.add.existing(crate, true);
+     this.crates.add(crate);
+   }
+ 
+   createActors() {
+     this.player = this.physics.add.sprite(80, this.scale.height / 2, null);
+     this.player.setSize(22, 22);
+     this.player.setCollideWorldBounds(true);
+ 
+     this.playerVisual = this.add.rectangle(0, 0, 22, 22, GAME.colors.player);
+     this.playerVisual.setStrokeStyle(2, 0x0f0f0f);
+ 
+     this.oldMan = this.physics.add.staticSprite(145, 120, null);
+     this.oldMan.setSize(22, 28);
+     this.oldManVisual = this.add.rectangle(145, 120, 22, 28, GAME.colors.oldMan);
+ 
+     this.hunter = this.physics.add.sprite(830, 450, null);
+     this.hunter.setSize(24, 24);
+     this.hunterVisual = this.add.rectangle(0, 0, 24, 24, GAME.colors.hunter);
+ 
+     this.hunterSpeed = GAME.speed.hunter + this.delivery.hunterSpeedBoost;
+   }
+ 
+   createObjectives() {
+     this.deliverySpot = this.physics.add.staticSprite(188, 120, null);
+     this.deliverySpotVisual = this.add.rectangle(188, 120, 22, 22, 0xb4e4b4);
+ 
+     this.keyItem = this.physics.add.staticSprite(790, 95, null);
+     this.keyVisual = this.add.rectangle(790, 95, 14, 14, GAME.colors.key);
+ 
+     this.switches = [
+       this.createSwitch(210, 468),
+       this.createSwitch(530, 96),
+       this.createSwitch(825, 275),
+     ];
+   }
+ 
+   createSwitch(x, y) {
+     const zone = this.physics.add.staticSprite(x, y, null);
+     zone.setSize(24, 24);
+ 
+     const light = this.add.rectangle(x, y, 24, 24, GAME.colors.switchOff);
+     light.setStrokeStyle(2, 0x111111);
+ 
+     return { zone, light, active: false };
+   }
+ 
+   createUi() {
+     this.deliveryTitle = addLabel(this, 18, 12, this.delivery.title, 20, "#ffcdcd");
+     this.storyLabel = addLabel(this, 18, 44, `"${this.delivery.intro}"`, 16, "#edd2d2");
+     this.objectiveLabel = addLabel(this, 18, 95, "", 18, "#9af7d8");
+     this.hintLabel = addLabel(this, 18, 124, "", 16, "#ffd59f");
+ 
+     this.updateObjectiveText();
+   }
+ 
+   configureCollisions() {
+     this.physics.add.collider(this.player, this.walls);
+     this.physics.add.collider(this.player, this.crates);
+     this.physics.add.collider(this.hunter, this.walls);
+     this.physics.add.collider(this.hunter, this.crates);
+ 
+     this.physics.add.overlap(this.player, this.hunter, () => {
+       this.scene.start("end", { outcome: "caught" });
+     });
+   }
+ 
+   startAmbientEvents() {
+     if (!this.delivery.hasFakeNoise) {
+       return;
+     }
+ 
+     this.time.addEvent({
+       delay: 3900,
+       loop: true,
+       callback: () => {
+         const lines = [
+           "You hear metal scraping behind you.",
+           "A freezer door slams in another room.",
+           "Someone whispers: 'Fresh delivery...'",
+         ];
+         const line = Phaser.Utils.Array.GetRandom(lines);
+         this.hintLabel.setText(line);
+ 
+         this.time.delayedCall(1300, () => this.updateHint());
+       },
+     });
+   }
+ 
+   update() {
+     this.handleMovement();
+     this.syncVisuals();
+     this.updateHunterAi();
+     this.handleInteractions();
+     this.handleExitReach();
+   }
+ 
+   handleMovement() {
+     const moveSpeed = this.keys.sprint.isDown ? GAME.speed.sprint : GAME.speed.player;
+     let dx = 0;
+     let dy = 0;
+ 
+     if (this.keys.left.isDown || this.keys.leftAlt.isDown) {
+       dx -= 1;
+     }
+     if (this.keys.right.isDown || this.keys.rightAlt.isDown) {
+       dx += 1;
+     }
+     if (this.keys.up.isDown || this.keys.upAlt.isDown) {
+       dy -= 1;
+     }
+     if (this.keys.down.isDown || this.keys.downAlt.isDown) {
+       dy += 1;
+     }
+ 
+     const velocity = new Phaser.Math.Vector2(dx, dy).normalize().scale(moveSpeed);
+     this.player.body.setVelocity(velocity.x, velocity.y);
+   }
+ 
+   syncVisuals() {
+     this.playerVisual.setPosition(this.player.x, this.player.y);
+     this.hunterVisual.setPosition(this.hunter.x, this.hunter.y);
+   }
+ 
+   updateHunterAi() {
+     const target = new Phaser.Math.Vector2(this.player.x - this.hunter.x, this.player.y - this.hunter.y)
+       .normalize()
+       .scale(this.hunterSpeed);
+ 
+     this.hunter.setVelocity(target.x, target.y);
+   }
+ 
+   handleInteractions() {
+     if (!Phaser.Input.Keyboard.JustDown(this.interactKey)) {
+       return;
+     }
+ 
+     if (!this.hasDelivered && this.isNear(this.player, this.deliverySpot)) {
+       this.hasDelivered = true;
+       this.deliverySpotVisual.setFillStyle(0x6c9d6c);
+       this.updateObjectiveText();
+       this.hintLabel.setText("Package dropped. Great. Why did the lights flicker?");
+       return;
+     }
+ 
+     if (!this.hasKey && this.isNear(this.player, this.keyItem)) {
+       this.hasKey = true;
+       this.keyVisual.setVisible(false);
+       this.updateObjectiveText();
+       this.hintLabel.setText("Got key. Your hand smells like rust now.");
+       return;
+     }
+ 
+     const nextSwitch = this.switches.find(
+       (entry) => !entry.active && this.isNear(this.player, entry.zone)
+     );
+ 
+     if (nextSwitch && this.hasDelivered) {
+       nextSwitch.active = true;
+       nextSwitch.light.setFillStyle(GAME.colors.switchOn);
+       this.switchesActive += 1;
+       this.updateObjectiveText();
+       this.updateHint();
+       return;
+     }
+ 
+     this.hintLabel.setText("Nothing useful to interact with here.");
+   }
+ 
+   handleExitReach() {
+     if (!this.hasDelivered || !this.hasKey) {
+       return;
+     }
+ 
+     if (this.switchesActive < this.delivery.requiredSwitches) {
+       return;
+     }
+ 
+     if (!this.isExitUnlocked) {
+       this.isExitUnlocked = true;
+       this.exitDoor.setFillStyle(GAME.colors.exitOpen);
+       this.hintLabel.setText("Exit unlocked! Reach the door before he reaches you.");
+       this.updateObjectiveText();
+     }
+ 
+     if (!this.isNear(this.player, this.exitDoor, 30)) {
+       return;
+     }
+ 
+     runState.completedDeliveries += 1;
+ 
+     const isLastDelivery = this.deliveryIndex >= DELIVERIES.length - 1;
+     if (isLastDelivery) {
+       this.scene.start("end", { outcome: "escaped" });
+       return;
+     }
+ 
+     runState.startNextDelivery();
+     this.scene.start("delivery", { deliveryIndex: this.deliveryIndex + 1 });
+   }
+ 
+   updateObjectiveText() {
+     const switchNeed = this.delivery.requiredSwitches;
+     const switchText = `${this.switchesActive}/${switchNeed}`;
+ 
+     if (!this.hasDelivered) {
+       this.objectiveLabel.setText("Objective: Deliver meat at the front counter (E)");
+       this.updateHint();
+       return;
+     }
+ 
+     if (!this.hasKey) {
+       this.objectiveLabel.setText("Objective: Find the freezer key (E)");
+       this.updateHint();
+       return;
+     }
+ 
+     if (!this.isExitUnlocked) {
+       this.objectiveLabel.setText(`Objective: Activate power switches (${switchText})`);
+       this.updateHint();
+       return;
+     }
+ 
+     this.objectiveLabel.setText("Objective: Escape through the right-side exit NOW");
+     this.updateHint();
+   }
+ 
+   updateHint() {
+     if (!this.hasDelivered) {
+       this.hintLabel.setText("The old man is waiting by the counter.");
+       return;
+     }
+ 
+     if (!this.hasKey) {
+       this.hintLabel.setText("Try the top-right corner. Something glints there.");
+       return;
+     }
+ 
+     if (!this.isExitUnlocked) {
+       this.hintLabel.setText("Flip unlit switches. Keep moving.");
+       return;
+     }
+ 
+     this.hintLabel.setText("Do not look back. Just run.");
+   }
+ 
+   isNear(a, b, threshold = INTERACT_DISTANCE) {
+     return Phaser.Math.Distance.Between(a.x, a.y, b.x, b.y) <= threshold;
+   }
+ }

